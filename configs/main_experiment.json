{
  "llm": {
    "primary_model": "gemini-3.1-flash-lite",
    "fallback_models": ["gemini-3.1-flash-lite"],
    "base_url": "https://api.aimlapi.com/v1",
    "batch_size": 8,
    "chunk_size": 50000,
    "min_cluster_size": 2,
    "disable_fallback": false,
    "request_timeout_seconds": 60,
    "max_retries": 1
  },
  "datasets": [
    {
      "name": "Wilson_50000",
      "log_path": "data/raw/Wilson/Wilson_50000.log",
      "gt_path": "data/ground_truth/Wilson/Wilson_gt.csv",
      "matching": "line_index"
    },
    {
      "name": "University_50000",
      "log_path": "data/raw/University/University_50000.log",
      "gt_path": "data/ground_truth/University/University_gt.csv",
      "matching": "line_index"
    },
    {
      "name": "HS_full",
      "log_path": "data/raw/HS/HS_full.log",
      "gt_path": "data/ground_truth/HS/HS_gt.csv",
      "matching": "record",
      "exclude_client_in_fea": true,
      "field_metrics_on_extracted_only": true
    }
  ]
}

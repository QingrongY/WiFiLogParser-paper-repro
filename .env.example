# Required
LLM_API_KEY=your_api_key_here

# Optional (OpenRouter example)
LLM_BASE_URL=https://openrouter.ai/api/v1

# Optional model config
LLM_PRIMARY_MODEL=google/gemini-2.0-flash
LLM_FALLBACK_MODELS=google/gemini-2.0-flash
LLM_BATCH_SIZE=8
LLM_CHUNK_SIZE=50000
LLM_MIN_CLUSTER_SIZE=2
LLM_DISABLE_FALLBACK=false
LLM_REQUEST_TIMEOUT_SECONDS=60
LLM_MAX_RETRIES=1

# Required
LLM_API_KEY=your_api_key_here

# Default provider matches production deployment (AIMLAPI).
# To use OpenRouter instead, set LLM_BASE_URL=https://openrouter.ai/api/v1
# and use the provider-prefixed model slug (e.g. google/gemini-flash-lite-latest).
LLM_BASE_URL=https://api.aimlapi.com/v1

# Default model: matches production at https://wildash.space
LLM_PRIMARY_MODEL=gemini-3.1-flash-lite
LLM_FALLBACK_MODELS=gemini-3.1-flash-lite
LLM_BATCH_SIZE=8
LLM_CHUNK_SIZE=50000
LLM_MIN_CLUSTER_SIZE=2
LLM_DISABLE_FALLBACK=false
LLM_REQUEST_TIMEOUT_SECONDS=60
LLM_MAX_RETRIES=1
